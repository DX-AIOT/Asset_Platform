# ==============================================
# DX Solutions AIoT Asset Platform
# Environment Variables Template
# ==============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ============== API Configuration ==============
API_PORT=3001
API_HOST=localhost
NODE_ENV=development

# ============== Database / Cache ==============
# Host-run backend (outside Docker):
# DATABASE_URL=postgresql://asset_user:asset_pass_dev@localhost:5432/asset_platform
# REDIS_URL=redis://localhost:6379
#
# Docker Compose backend (api service in docker-compose.yml):
DATABASE_URL=postgresql://asset_user:asset_pass_dev@postgres:5432/asset_platform
REDIS_URL=redis://redis:6379

# ============== Authentication ==============
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-change-me
REFRESH_TOKEN_EXPIRES_IN=30d

# ============== AWS Services (Optional) ==============
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# ============== OpenAI ==============
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_LOCAL_MODE=true
OPENAI_OCR_MODEL=gpt-4.1-mini

# ============== Web App (Next.js) ==============
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_NAME=Asset Platform

# ============== Mobile App ==============
EXPO_PUBLIC_API_URL=http://localhost:3001/api

# ============== Email Service ==============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ============== Logging & Monitoring ==============
LOG_LEVEL=info
SENTRY_DSN=your-sentry-dsn-if-using

# ============== External APIs ==============
# Add any third-party API keys here

# ============== MoMo Payment Gateway ==============
# LOCAL / STG: use MoMo sandbox endpoint
# PRD: replace with https://payment.momo.vn
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn
