{
  "name": "@dx-aiot/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "start": "expo start",
    "test": "NODE_ENV=test jest --passWithNoTests",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.[jt]sx?$": ["ts-jest", { "tsconfig": { "strict": false, "jsx": "react-jsx" }, "diagnostics": false }]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(@react-native|react-native|expo|@expo)/)"
    ],
    "moduleNameMapper": {
      "^react-native$": "<rootDir>/../../node_modules/react-native",
      "^expo-notifications$": "<rootDir>/../../node_modules/expo-notifications",
      "^expo-device$": "<rootDir>/../../node_modules/expo-device",
      "^expo-secure-store$": "<rootDir>/../../node_modules/expo-secure-store",
      "^expo-router$": "<rootDir>/../../node_modules/expo-router"
    },
    "modulePaths": ["<rootDir>/../../node_modules"],
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx", "json"],
    "testMatch": ["**/__tests__/**/*.[jt]s?(x)"]
  },
  "dependencies": {
    "@react-navigation/native": "^6.1.9",
    "axios": "^1.6.5",
    "expo": "~50.0.0",
    "expo-camera": "~14.0.0",
    "expo-device": "~5.9.0",
    "expo-file-system": "~16.0.0",
    "expo-image-picker": "~14.7.1",
    "expo-notifications": "~0.27.6",
    "expo-router": "~3.4.0",
    "expo-secure-store": "~12.8.1",
    "expo-status-bar": "~1.11.1",
    "react": "18.2.0",
    "react-native": "0.73.0",
    "react-native-safe-area-context": "4.8.2",
    "react-native-screens": "~3.29.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.4.5",
    "@types/react": "~18.2.45",
    "jest-expo": "~50.0.0",
    "typescript": "^5.3.3"
  }
}
